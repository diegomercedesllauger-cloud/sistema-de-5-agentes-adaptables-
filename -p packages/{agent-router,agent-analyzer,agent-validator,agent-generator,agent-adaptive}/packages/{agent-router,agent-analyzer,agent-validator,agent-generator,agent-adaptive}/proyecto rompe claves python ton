class PasswordLearner:
    """
    Aprende del feedback del usuario
    
    Ejemplo:
    Usuario dice: "Eso es demasiado complejo"
    → Sistema aprende: próximas sugerencias serán SIMPLES
    
    Usuario dice: "Me gustó la segunda opción"
    → Sistema aprende: usuario prefiere BALANCEADA
    
    Este es el sistema ADAPTATIVO del proyecto.
    """
    
    def __init__(self, memory_dir: str = "./storage/user_memory"):
        """Inicializa el aprendiz"""
        self.memory_dir = memory_dir
        os.makedirs(memory_dir, exist_ok=True)
    
    def process_feedback(self, user_id: str, feedback: str,
                        contexto: Dict) -> Dict:
        """
        Procesa feedback y adapta preferencias
        
        Args:
            user_id: ID único del usuario
            feedback: Lo que dice ("Eso fue fácil", "Muy complejo", etc.)
            contexto: Contexto (qué se sugirió, qué le gustó)
            
        Returns:
            Confirmación de aprendizaje
        """
        
        # Cargar preferencias actuales
        prefs = self._load_preferences(user_id)
        
        # Extraer lecciones del feedback
        lecciones = self._extract_lessons(feedback)
        
        # Actualizar preferencias
        for leccion in lecciones:
            if "simple" in leccion.lower():
                prefs["complejidad"] = "simple"
            elif "complejo" in leccion.lower() or "paranoia" in leccion.lower():
                prefs["complejidad"] = "paranoia"
            elif "balanceado" in leccion.lower() or "medio" in leccion.lower():
                prefs["complejidad"] = "balanceada"
            
            if "largo" in leccion.lower():
                prefs["longitud_minima"] = 16
            elif "corto" in leccion.lower():
                prefs["longitud_minima"] = 10
        
        # Guardar
        self._save_preferences(user_id, prefs)
        
        return {
            "status": "APRENDIDO",
            "feedback_procesado": feedback,
            "lecciones_extraidas": lecciones,
            "nuevas_preferencias": prefs,
            "mensaje": "Sistema adaptado. Próximas sugerencias serán diferentes.",
            "próxima_sugerencia": f"Usará complejidad: {prefs.get('complejidad')}"
        }
    
    def _extract_lessons(self, feedback: str) -> List[str]:
        """Extrae lecciones del feedback"""
        
        keywords = {
            "simple": ["fácil", "simple", "corto", "básico", "no muy complejo"],
            "balanceada": ["bien", "perfecto", "medio", "balance"],
            "paranoia": ["paranoia", "complejo", "fuerte", "muy fuerte", "seguro"],
            "largo": ["largo", "más largo", "más caracteres"],
            "corto": ["corto", "menos caracteres", "no tan largo"]
        }
        
        feedback_lower = feedback.lower()
        lecciones = []
        
        for leccion, palabras_clave in keywords.items():
            for palabra in palabras_clave:
                if palabra in feedback_lower:
                    lecciones.append(leccion)
                    break
        
        return lecciones if lecciones else ["feedback_recibido"]
    
    def _load_preferences(self, user_id: str) -> Dict:
        """Carga preferencias del usuario"""
        
        filepath = os.path.join(self.memory_dir, f"{user_id}_prefs.json")
        
        if os.path.exists(filepath):
            with open(filepath, 'r') as f:
                return json.load(f)
        
        # Por defecto
        return {
            "user_id": user_id,
            "complejidad": "balanceada",
            "longitud_minima": 12,
            "nivel_detalle": "simple"
        }
    
    def _save_preferences(self, user_id: str, prefs: Dict) -> bool:
        """Guarda preferencias"""
        
        filepath = os.path.join(self.memory_dir, f"{user_id}_prefs.json")
        
        with open(filepath, 'w') as f:
            json.dump(prefs, f, indent=2)
        
        return True
 
 
