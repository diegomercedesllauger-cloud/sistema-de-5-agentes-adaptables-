            "Caractereres repetidos": {
                "simple": "Evita AAA, 111, etc.",
                "intermedio": "Repeticiones indican patrón. Debilita contra ataques de diccionario.",
                "avanzado": "Patrones reducen espacio de búsqueda efectivo."
            },
            "Termina en año": {
                "simple": "No termines con años (2024, 1999, etc.).",
                "intermedio": "Los años son patrones humanos obvios. Atacante prueba todos los años primero.",
                "avanzado": "Patrón predecible = primeros en diccionario del atacante. Evitar completamente."
            }
        }
        
        return lecciones_map.get(problema, {}).get(nivel)
    
    def _generar_resumen(self, analisis: Dict, ataque: Dict, 
                        nivel: str) -> str:
        """Genera resumen ejecutivo"""
        
        fortaleza = analisis.get("fortaleza", "DESCONOCIDA")
        se_crackea = ataque.get("se_crackea", False)
        
        if se_crackea:
            if nivel == "simple":
                return (
                    f"⚠️ CRÍTICA: Tu contraseña se puede crackear. "
                    f"Cambiar INMEDIATAMENTE."
                )
            else:
                return (
                    f"Tu contraseña es vulnerable a ataques. "
                    f"Se crackea en {ataque.get('tiempo_estimado_real', {}).get('legible')}. "
                    f"Crear nueva contraseña forte."
                )
        else:
            if fortaleza == "MUY_FUERTE":
                return "✓ Excelente contraseña. Resistente a ataques."
            elif fortaleza == "FUERTE":
                return "✓ Buena contraseña. Aceptable pero puede mejorar."
            else:
                return "⚠️ Contraseña débil. Seguir recomendaciones."
    
    def _generar_pasos(self, analisis: Dict, nivel: str) -> List[str]:
        """Genera pasos a seguir"""
        
        pasos = []
        score = analisis.get("score", 0)
        
        # Paso 1: Evaluación
        pasos.append(f"1. Tu puntuación actual: {score}/100")
        
        # Paso 2: Problemas específicos
        problemas = analisis.get("problemas", [])
        if problemas:
            pasos.append(f"2. Problemas encontrados: {len(problemas)}")
            pasos.append("   " + " • ".join(problemas[:3]))
        
        # Paso 3: Mejora
        if score < 75:
            pasos.append("3. Crear contraseña más fuerte (ver sugerencias)")
        else:
            pasos.append("3. Contraseña aceptable, considera mejoras")
        
        # Paso 4: Protección
        pasos.append("4. Usar gestor de contraseñas")
        pasos.append("5. Activar autenticación de dos factores (2FA)")
        
        return pasos
 
 
