            """
🔐 AGENTE 1: ANALIZADOR DE CONTRASEÑAS
========================================
 
Función: Evaluar fortaleza de una contraseña
 
¿Qué hace?
- Calcula entropía (bits de aleatoriedad)
- Detecta patrones (nombres, números secuenciales, etc.)
- Asigna puntuación 0-100
- Estima tiempo para crackear con GPU moderna
- Identifica problemas específicos
 
Autor: Diego Mercedes Llauger (2026-0048)
Para: Ingeniería en Ciberseguridad
"""
 
import re
import math
from typing import Dict, List
from dataclasses import dataclass
from datetime import datetime
 
 
@dataclass
class CharacterSet:
    """Define conjuntos de caracteres para cálculo de entropía"""
    lowercase: str = "abcdefghijklmnopqrstuvwxyz"
    uppercase: str = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    digits: str = "0123456789"
    special: str = "!@#$%^&*()_+-=[]{}|;:,.<>?"
 
 
class PasswordAnalyzer:
    """
    Analiza contraseñas y proporciona puntuación de fortaleza
    
    Ejemplo de uso:
        analyzer = PasswordAnalyzer()
        resultado = analyzer.analyze("diego2024")
        print(resultado["fortaleza"])  # Output: DÉBIL
        print(resultado["score"])      # Output: 25
    """
    
    def __init__(self):
        """Inicializa el analizador"""
        self.charset = CharacterSet()
        self.common_patterns = {
            r"[0-9]{4}$": "año",
            r"[0-9]{2}[a-z]+": "número+letras",
            r"[a-z]{3,}[0-9]": "palabra+número",
            r"(.)\1{2,}": "caracteres repetidos",
            r"[a-z]{1,3}": "nombre corto",
            r"[0-9]{1,3}": "número pequeño",
        }
        self.common_passwords = [
            "123456", "password", "123456789", "12345678",
            "12345", "1234567", "password123", "123123",
            "1234567890", "000000", "111111", "abc123"
        ]
    
    def analyze(self, password: str) -> Dict:
        """
        Analiza una contraseña completamente
        
        Args:
            password: Contraseña a analizar
            
        Returns:
            Diccionario con:
                - score: 0-100
                - fortaleza: DÉBIL/MEDIA/FUERTE/MUY_FUERTE
                - entropía: bits
                - tiempo_crack: estimación legible
                - patrones: lista de patrones detectados
                - problemas: lista de problemas específicos
                - recomendaciones: qué mejorar
        """
        
        # Validación
        if not password or len(password) == 0:
            return self._empty_password_result()
        
        # Calcular componentes
        length_score = self._score_length(password)
        entropy = self._calculate_entropy(password)
        entropy_score = self._score_entropy(entropy)
        
        patterns = self._detect_patterns(password)
        pattern_score = self._score_patterns(patterns)
        
        diversity = self._character_diversity(password)
        diversity_score = self._score_diversity(diversity)
        
        problems = self._identify_problems(password, patterns, diversity)
        
        # Calcular score final (promedio ponderado)
        total_score = (
            length_score * 0.25 +      # 25% por longitud
            entropy_score * 0.35 +     # 35% por entropía
            diversity_score * 0.25 +   # 25% por diversidad
            pattern_score * 0.15       # 15% por patrones (negativo)
        )
        total_score = max(0, min(100, total_score))  # Limitar 0-100
        
        # Determinar fortaleza
        fortaleza = self._get_fortaleza(total_score)
        
        # Estimar tiempo para crackear
        tiempo_crack = self._estimate_crack_time(entropy, password)
        
        return {
            "timestamp": datetime.now().isoformat(),
            "contraseña_analizada": "***" if len(password) > 0 else "vacía",
            "longitud": len(password),
            
            # Puntuaciones desglosadas
            "puntuaciones": {
                "longitud": round(length_score, 1),
                "entropía": round(entropy_score, 1),
                "diversidad": round(diversity_score, 1),
                "patrones": round(pattern_score, 1)
            },
            
            # Resultado final
            "score": round(total_score, 1),
            "fortaleza": fortaleza,
            
            # Análisis técnico
            "técnico": {
                "entropía_bits": round(entropy, 2),
                "charset_usado": self._get_charset_description(password),
                "diversidad": {
                    "minúsculas": diversity["lowercase"],
                    "mayúsculas": diversity["uppercase"],
                    "números": diversity["digits"],
                    "especiales": diversity["special"]
                }
            },
            
            # Seguridad
            "seguridad": {
                "tiempo_crack_gpu": tiempo_crack["legible"],
                "tiempo_crack_segundos": tiempo_crack["segundos"],
                "combinaciones_posibles": f"2^{entropy:.0f}",
                "consideración": tiempo_crack["consideración"]
            },
            
            # Problemas detectados
            "problemas": problems,
            
            # Patrones detectados
            "patrones": patterns,
            
            # Recomendaciones
            "recomendaciones": self._get_recomendaciones(
                total_score, problems, len(password)
            )
        }
    
    def _score_length(self, password: str) -> float:
        """
        Puntúa según longitud
        
        POR QUÉ:
        Cada carácter adicional multiplica combinaciones posibles.
        8 caracteres = inseguro
        12+ caracteres = comienza a ser seguro
        16+ caracteres = muy seguro
        """
        length = len(password)
        
        # Tabla de puntuaciones
        if length < 6:
            return 10
        elif length < 8:
            return 25
        elif length < 10:
            return 45
        elif length < 12:
            return 65
        elif length < 14:
            return 80
        else:  # 14+
            return 95
    
    def _calculate_entropy(self, password: str) -> float:
        """
        Calcula entropía (bits de aleatoriedad)
        
        Fórmula: E = log2(N^L)
        Donde:
          N = número de caracteres posibles en el charset
          L = longitud de la contraseña
        
        Ejemplo:
          "diego2024" (9 caracteres, lowercase+digits)
          N = 26 + 10 = 36 caracteres posibles
          E = log2(36^9) = 46.9 bits
          
        ¿Qué significa?
        - 40 bits = puede crackerse en horas (GPU)
        - 60 bits = puede crackerse en años (GPU)
        - 80 bits = imprácticamente seguro (GPU)
        """
        
        # Determinar charset
        charset_size = 0
        if re.search(r'[a-z]', password):
            charset_size += len(self.charset.lowercase)
        if re.search(r'[A-Z]', password):
            charset_size += len(self.charset.uppercase)
        if re.search(r'[0-9]', password):
            charset_size += len(self.charset.digits)
        if re.search(rf'[{re.escape(self.charset.special)}]', password):
            charset_size += len(self.charset.special)
        
        # Si no detecta nada (no debería pasar), asumir
        if charset_size == 0:
            charset_size = 26
        
        # Calcular entropía
        entropy = math.log2(charset_size ** len(password))
        return entropy
    
    def _score_entropy(self, entropy: float) -> float:
        """Puntúa según entropía en bits"""
        if entropy < 30:
            return 15
        elif entropy < 40:
            return 30
        elif entropy < 50:
            return 50
        elif entropy < 60:
            return 70
        elif entropy < 75:
            return 85
        else:
            return 100
    
    def _character_diversity(self, password: str) -> Dict[str, bool]:
        """Detecta qué tipos de caracteres usa"""
        return {
            "lowercase": bool(re.search(r'[a-z]', password)),
            "uppercase": bool(re.search(r'[A-Z]', password)),
            "digits": bool(re.search(r'[0-9]', password)),
            "special": bool(re.search(rf'[{re.escape(self.charset.special)}]', password))
        }
    
    def _score_diversity(self, diversity: Dict[str, bool]) -> float:
        """Puntúa según diversidad de caracteres"""
        count = sum(diversity.values())
        
        if count == 1:
            return 20
        elif count == 2:
            return 50
        elif count == 3:
            return 75
        else:  # 4
            return 100
    
    def _detect_patterns(self, password: str) -> List[str]:
        """Detecta patrones problemáticos"""
        patterns = []
        
        # Patrones peligrosos
        if re.search(r'[0-9]{4}$', password):
            patterns.append("termina_en_año")
        
        if re.search(r'[0-9]{1,3}$', password):
            patterns.append("termina_en_número")
        
        if re.search(r'^[a-zA-Z]{1,5}', password):
            patterns.append("comienza_con_palabra_corta")
        
        if re.search(r'(.)\1{2,}', password):
            patterns.append("caracteres_repetidos")
        
        if re.search(r'123|234|345|456|567|678|789|890', password):
            patterns.append("números_secuenciales")
        
        if re.search(r'abc|bcd|cde|def', password.lower()):
            patterns.append("letras_secuenciales")
        
        if password.lower() in self.common_passwords:
            patterns.append("contraseña_común")
        
        return patterns if patterns else ["ninguno"]
    
    def _score_patterns(self, patterns: List[str]) -> float:
        """Puntúa negativamente según patrones detectados"""
        # Empezar alto, restar por cada patrón
        score = 100
        
        penalties = {
            "termina_en_año": 15,
            "termina_en_número": 10,
            "comienza_con_palabra_corta": 10,
            "caracteres_repetidos": 15,
            "números_secuenciales": 20,
            "letras_secuenciales": 20,
            "contraseña_común": 30,
            "ninguno": 0
        }
        
        for pattern in patterns:
            score -= penalties.get(pattern, 0)
        
        return max(0, score)
    
    def _identify_problems(self, password: str, patterns: List[str], 
                          diversity: Dict[str, bool]) -> List[str]:
        """Identifica problemas específicos"""
        problems = []
        
        # Longitud
        if len(password) < 8:
            problems.append("Demasiado corta (menos de 8 caracteres)")
        
        # Diversidad
        diversity_count = sum(diversity.values())
        if diversity_count == 1:
            problems.append("Solo usa un tipo de carácter")
        elif diversity_count == 2:
            problems.append("Usa solo 2 tipos de caracteres (necesita más variedad)")
        
        if not diversity["uppercase"]:
            problems.append("Falta MAYÚSCULAS")
        
        if not diversity["special"]:
            problems.append("Falta símbolos especiales (!@#$%)")
        
        # Patrones
        if "caracteres_repetidos" in patterns:
            problems.append("Tiene caracteres repetidos (AAA, 111)")
        
        if "números_secuenciales" in patterns:
            problems.append("Números en secuencia (123, 456)")
        
        if "contraseña_común" in patterns:
            problems.append("Es una contraseña común y muy fácil de crackear")
        
        if "termina_en_año" in patterns:
            problems.append("Termina en año (patrón fácil de adivinar)")
        
        return problems if problems else ["Ninguno detectado"]
    
    def _get_charset_description(self, password: str) -> str:
        """Describe el charset utilizado"""
        has_lower = bool(re.search(r'[a-z]', password))
        has_upper = bool(re.search(r'[A-Z]', password))
        has_digits = bool(re.search(r'[0-9]', password))
        has_special = bool(re.search(rf'[{re.escape(self.charset.special)}]', password))
        
        parts = []
        if has_lower:
            parts.append("minúsculas")
        if has_upper:
            parts.append("MAYÚSCULAS")
        if has_digits:
            parts.append("números")
        if has_special:
            parts.append("símbolos")
        
        return " + ".join(parts) if parts else "ninguno"
    
    def _estimate_crack_time(self, entropy: float, password: str) -> Dict:
        """
        Estima tiempo para crackear con GPU moderna
        
        GPU moderna: ~10 mil millones de intentos/segundo (10^10 hashes/seg)
        Fórmula: Tiempo (segundos) = 2^entropía / 2 / velocidad GPU
        
        El /2 es porque en promedio necesitas probar la mitad antes de encontrar
        """
        
        # Velocidad de GPU moderna (algoritmos como bcrypt/scrypt son más lentos)
        gpu_speed = 1e10  # 10 mil millones hashes/segundo
        
        # Casos especiales
        if password in self.common_passwords:
            return {
                "segundos": 0.001,
                "legible": "Menos de 1 ms (está en diccionario)",
                "consideración": "CRÍTICA: Se crackea instantáneamente"
            }
        
        # Cálculo
        combinaciones_posibles = 2 ** entropy
        tiempo_promedio = combinaciones_posibles / 2 / gpu_speed
        
        # Convertir a unidad legible
        if tiempo_promedio < 1:
            return {
                "segundos": tiempo_promedio,
                "legible": f"{tiempo_promedio*1000:.2f} milisegundos",
                "consideración": "CRÍTICA: Muy rápido"
            }
        elif tiempo_promedio < 60:
            return {
                "segundos": tiempo_promedio,
                "legible": f"{tiempo_promedio:.1f} segundos",
                "consideración": "CRÍTICA: Demasiado rápido"
            }
        elif tiempo_promedio < 3600:
            return {
                "segundos": tiempo_promedio,
                "legible": f"{tiempo_promedio/60:.1f} minutos",
                "consideración": "CRÍTICA: Muy vulnerable"
            }
        elif tiempo_promedio < 86400:
            return {
                "segundos": tiempo_promedio,
                "legible": f"{tiempo_promedio/3600:.1f} horas",
                "consideración": "CRÍTICA: Vulnerable"
            }
        elif tiempo_promedio < 86400 * 365:
            return {
                "segundos": tiempo_promedio,
                "legible": f"{tiempo_promedio/(86400):.1f} días",
                "consideración": "ADVERTENCIA: Débil a largo plazo"
            }
        elif tiempo_promedio < 86400 * 365 * 100:
            return {
                "segundos": tiempo_promedio,
                "legible": f"{tiempo_promedio/(86400*365):.1f} años",
                "consideración": "ACEPTABLE pero mejorable"
            }
        else:
            return {
                "segundos": tiempo_promedio,
                "legible": f"{tiempo_promedio/(86400*365*100):.0f}+ siglos",
                "consideración": "BUENO: Muy difícil de crackear"
            }
    
    def _get_fortaleza(self, score: float) -> str:
        """Clasifica fortaleza según score"""
        if score < 25:
            return "DÉBIL"
        elif score < 50:
            return "MEDIA"
        elif score < 75:
            return "FUERTE"
        else:
            return "MUY_FUERTE"
    
    def _get_recomendaciones(self, score: float, problems: List[str], 
                            length: int) -> List[str]:
        """Genera recomendaciones personalizadas"""
        recomendaciones = []
        
        if length < 12:
            recomendaciones.append("Aumenta a 12+ caracteres (mínimo recomendado)")
        
        if "Falta MAYÚSCULAS" in problems:
            recomendaciones.append("Incluye al menos 1 MAYÚSCULA")
        
        if "Falta símbolos especiales" in problems:
            recomendaciones.append("Incluye símbolos especiales: !@#$%^&*()")
        
        if "caracteres_repetidos" in str(problems):
            recomendaciones.append("Evita caracteres repetidos (AAA, 111)")
        
        if score < 50:
            recomendaciones.append("Cambia la contraseña pronto")
        
        if not recomendaciones:
            recomendaciones.append("Contraseña aceptable, pero sigue mejorando")
        
        return recomendaciones
    
    def _empty_password_result(self) -> Dict:
        """Resultado para contraseña vacía"""
        return {
            "error": "Contraseña vacía",
            "score": 0,
            "fortaleza": "NULA"
        }
 
 
