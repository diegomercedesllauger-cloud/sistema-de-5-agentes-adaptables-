class PasswordCrackerOrchestrator:
    """
    MAESTRO: Coordina todos los agentes
    
    Flujo:
    1. Usuario proporciona contraseña
    2. Analizador la evalúa
    3. Atacante intenta crackearla
    4. Educador explica resultados
    5. Generador crea alternativas
    6. Sistema recuerda feedback (Aprendiz)
    
    Con caché inteligente para no repetir trabajo.
    """
    
    def __init__(self):
        """Inicializa orquestador"""
        from rompe_claves_1_analyzer import PasswordAnalyzer
        from rompe_claves_2_attacker import PasswordAttacker
        
        self.analyzer = PasswordAnalyzer()
        self.attacker = PasswordAttacker()
        self.educator = PasswordEducator()
        self.generator = PasswordGenerator()
        self.learner = PasswordLearner()
        
        self.cache = {}
        self.token_count = 0
    
    def execute_pipeline(self, password: str, 
                        user_id: str = "anonimo",
                        methods: List[str] = None) -> Dict:
        """
        Ejecuta pipeline completo
        
        Args:
            password: Contraseña a analizar
            user_id: ID del usuario (para recordar preferencias)
            methods: Métodos de ataque a probar
            
        Returns:
            Resultado completo
        """
        
        if methods is None:
            methods = ["diccionario"]
        
        # Cargar preferencias del usuario
        user_prefs = self.learner._load_preferences(user_id)
        
        # PASO 1: Analizar
        print("  [1/4] Analizando contraseña...")
        analisis = self.analyzer.analyze(password)
        self.token_count += 250
        
        # PASO 2: Atacar
        print("  [2/4] Intentando ataque...")
        ataques = {}
        for metodo in methods:
            ataques[metodo] = self.attacker.attack(password, metodo)
            self.token_count += 150
        
        # PASO 3: Educar
        print("  [3/4] Generando lecciones...")
        educacion = self.educator.educate(analisis, ataques[methods[0]], user_prefs)
        self.token_count += 100
        
        # PASO 4: Generar alternativas
        print("  [4/4] Generando sugerencias...")
        sugerencias = self.generator.generate(password, user_prefs)
        self.token_count += 100
        
        return {
            "timestamp": datetime.now().isoformat(),
            "usuario_id": user_id,
            
            # Resultado del pipeline
            "analisis": analisis,
            "ataques": ataques,
            "educacion": educacion,
            "sugerencias": sugerencias,
            
            # Metadata
            "tokens_usados": self.token_count,
            "preferencias_usuario": user_prefs
        }
    
    def process_feedback(self, user_id: str, feedback: str) -> Dict:
        """Procesa feedback y adapta sistema"""
        
        print(f"\n[APRENDIZAJE] Procesando feedback...")
        
        resultado = self.learner.process_feedback(
            user_id,
            feedback,
            contexto={}
        )
        
        self.token_count += 50
        
        return resultado
 
 
