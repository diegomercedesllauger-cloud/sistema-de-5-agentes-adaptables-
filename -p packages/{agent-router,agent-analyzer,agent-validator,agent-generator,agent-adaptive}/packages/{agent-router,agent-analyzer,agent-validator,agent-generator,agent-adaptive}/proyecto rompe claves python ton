class PasswordGenerator:
    """
    Genera contraseñas mejoradas
    
    Crea 3 variantes:
    - SIMPLE: Mejora mínima
    - BALANCEADA: Balance entre seguridad y usabilidad
    - PARANOIA: Máxima seguridad (aleatoria)
    """
    
    def __init__(self):
        """Inicializa el generador"""
        self.symbols = "!@#$%^&*()"
    
    def generate(self, base_password: Optional[str] = None,
                user_prefs: Optional[Dict] = None) -> Dict:
        """
        Genera contraseñas mejoradas
        
        Args:
            base_password: Contraseña actual (para mejora incremental)
            user_prefs: Preferencias (complejidad, longitud)
            
        Returns:
            3 sugerencias: simple, balanceada, paranoia
        """
        
        if user_prefs is None:
            user_prefs = {}
        
        preferidas = user_prefs.get("complejidad", "balanceada")
        longitud_min = user_prefs.get("longitud_minima", 12)
        
        sugerencias = [
            self._generar_simple(longitud_min),
            self._generar_balanceada(longitud_min + 2),
            self._generar_paranoia(longitud_min + 4)
        ]
        
        return {
            "timestamp": datetime.now().isoformat(),
            "sugerencias": sugerencias,
            "recomendación": self._recomendar(preferidas),
            "cómo_usar": [
                "1. Elige una sugerencia según tus preferencias",
                "2. Memoriza o guarda en gestor de contraseñas",
                "3. NO la escribas en papel o notas",
                "4. NO la compartas con nadie",
                "5. Usa diferente para cada sitio importante"
            ]
        }
    
    def _generar_simple(self, length: int) -> Dict:
        """Genera contraseña SIMPLE"""
        
        # Estrategia: Palabra memorable + número + símbolo
        palabras = ["Dragon", "Phoenix", "Tiger", "Eagle", "Shadow"]
        palabra = random.choice(palabras)
        
        numero = str(random.randint(1000, 9999))
        simbolo = random.choice(self.symbols)
        
        password = f"{palabra}{numero}{simbolo}"
        
        return {
            "tipo": "SIMPLE",
            "contraseña": password,
            "longitud": len(password),
            "score_estimado": 70,
            "ventajas": [
                "Relativamente fácil de recordar",
                "Palabra memorable + números + símbolo"
            ],
            "desventajas": [
                "Basada en palabra (menos aleatoria)",
                "Patrón predecible: palabra+número+símbolo"
            ]
        }
    
    def _generar_balanceada(self, length: int) -> Dict:
        """Genera contraseña BALANCEADA"""
        
        # Estrategia: Aleatoria pero comprensible
        chars = (
            string.ascii_uppercase +
            string.ascii_lowercase +
            string.digits +
            self.symbols
        )
        
        password = ''.join(random.choice(chars) for _ in range(length))
        
        return {
            "tipo": "BALANCEADA",
            "contraseña": password,
            "longitud": len(password),
            "score_estimado": 90,
            "ventajas": [
                "Altamente aleatoria",
                "Difícil de crackear",
                "Longitud segura"
            ],
            "desventajas": [
                "Difícil de recordar",
                "DEBES usar gestor de contraseñas"
            ]
        }
    
    def _generar_paranoia(self, length: int) -> Dict:
        """Genera contraseña PARANOIA (máxima seguridad)"""
        
        # Estrategia: Completamente aleatoria, muy larga
        chars = (
            string.ascii_uppercase +
            string.ascii_lowercase +
            string.digits +
            self.symbols
        )
        
        password = ''.join(random.choice(chars) for _ in range(length))
        
        return {
            "tipo": "PARANOIA",
            "contraseña": password,
            "longitud": len(password),
            "score_estimado": 99,
            "ventajas": [
                "Prácticamente imposible de crackear",
                "Longitud máxima (24+ caracteres)",
                "Aleatoriedad máxima"
            ],
            "desventajas": [
                "Totalmente imposible de recordar",
                "OBLIGATORIO usar gestor de contraseñas",
                "Impráctica para sitios sin soporte"
            ]
        }
    
    def _recomendar(self, preferencia: str) -> str:
        """Recomienda según preferencia del usuario"""
        recomendaciones = {
            "simple": "Para cuentas secundarias o no críticas",
            "balanceada": "Recomendado para la mayoría (buen balance)",
            "paranoia": "Para cuentas críticas (email, banco, trabajo)"
        }
        return recomendaciones.get(preferencia, "Elige según tus necesidades")
 
 
