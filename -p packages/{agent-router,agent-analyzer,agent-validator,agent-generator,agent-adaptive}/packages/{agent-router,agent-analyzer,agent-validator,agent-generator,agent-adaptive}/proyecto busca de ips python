            total_hallazgos=reporte['estadisticas']['total_hallazgos'],
            puertos_abiertos=reporte['estadisticas']['puertos_abiertos'],
            vulnerabilidades=reporte['estadisticas']['vulnerabilidades_encontradas'],
            criticos=reporte['estadisticas']['criticos'],
            hallazgos_html=hallazgos_html,
            recomendaciones_html=recomendaciones_html,
            conclusiones=reporte['conclusiones']
        )
        
        # Guardar archivo
        nombre_archivo = f"reporte_{ip_objetivo.replace('.', '_')}.html"
        with open(nombre_archivo, 'w', encoding='utf-8') as f:
            f.write(html)
        
        print(f"\n[+] Reporte HTML generado: {nombre_archivo}")
        return nombre_archivo
    
    def exportar_json(self, reporte: Dict, ip_objetivo: str) -> str:
        """Exporta reporte a JSON."""
        
        nombre_archivo = f"reporte_{ip_objetivo.replace('.', '_')}.json"
        with open(nombre_archivo, 'w', encoding='utf-8') as f:
            json.dump(reporte, f, indent=2, ensure_ascii=False)
        
