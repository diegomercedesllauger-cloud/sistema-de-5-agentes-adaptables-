            <p><strong>Prioridad:</strong> {rec['prioridad']} | <strong>Plazo:</strong> {rec['plazo']}</p>
            <p>{rec['descripción']}</p>
            {pasos_html}
        </div>
"""
        
        # Reemplazar placeholders
        html = html.format(
            fecha=reporte['metadata']['fecha'],
            ip=reporte['metadata']['ip_objetivo'],
            timestamp=reporte['metadata']['timestamp'],
            nivel_riesgo=reporte['nivel_riesgo_general'],
            nivel_riesgo_clase=reporte['nivel_riesgo_general'].split()[0].lower().replace('🔴', 'critico').replace('🟠', 'alto').replace('🟡', 'medio').replace('🟢', 'bajo'),
