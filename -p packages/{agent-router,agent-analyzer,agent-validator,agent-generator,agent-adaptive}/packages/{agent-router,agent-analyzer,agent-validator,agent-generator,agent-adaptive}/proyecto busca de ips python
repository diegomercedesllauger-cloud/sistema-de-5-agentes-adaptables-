class ServiceEnumerator:
    """
    Enumerador de servicios y versiones.
    
    Objetivo: Conectarse a puertos abiertos y obtener información sobre
    qué servicio corre, en qué versión, y qué vulnerabilidades tiene.
    
    Autor: Diego Mercedes Llauger (2026-0048)
    """
    
    # Base de datos de CVEs (En producción, usarías API de NVD)
    CVE_DATABASE = {
        ("OpenSSH", "7.4"): [
            {
                "cve": "CVE-2018-15473",
                "descripción": "User enumeration via timing side-channel",
                "severidad": "MEDIA",
