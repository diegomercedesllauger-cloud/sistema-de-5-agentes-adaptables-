    opcion = input("Opción (1 o 2): ").strip()
    
    if opcion == "1":
        puertos = list(PortScanner.PUERTOS_CONOCIDOS.keys())
    elif opcion == "2":
        # ⚠️ ADVERTENCIA: Escaneo completo toma MUCHO tiempo
        print("\n⚠️  Advertencia: Esto toma ~30 minutos")
        confirmar = input("¿Continuar? (S/N): ").strip().upper()
        if confirmar != "S":
            return
        puertos = range(1, 65536)
    else:
        print("Opción inválida")
        return
    
    # Timeout
    try:
        timeout = int(input("Timeout en segundos (recomendado: 3): ") or "3")
    except ValueError:
        timeout = 3
    
    # Ejecutar escaneo
    scanner = PortScanner(timeout=timeout)
    resultados = scanner.escanear_rango(ip, list(puertos))
    
    # Mostrar resultados
    scanner.mostrar_resultados(resultados)
    
    # Guardar resultados
    _guardar_resultados(ip, resultados)


def _validar_ip_formato(ip: str) -> bool:
    """Valida formato básico de IP."""
    try:
        partes = ip.split('.')
        if len(partes) != 4:
            return False
        for parte in partes:
            if not (0 <= int(parte) <= 255):
                return False
        return True
    except:
        return False


def _guardar_resultados(ip: str, resultados: Dict):
    """Guarda resultados en archivo."""
    import json
    
    nombre_archivo = f"escaneo_{ip.replace('.', '_')}.json"
    
    try:
        with open(nombre_archivo, 'w', encoding='utf-8') as f:
            json.dump(resultados, f, indent=2, ensure_ascii=False)
        print(f"\n✓ Resultados guardados en: {nombre_archivo}")
    except Exception as e:
        print(f"\n⚠️  Error guardando resultados: {e}")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\n⛔ Escaneo interrumpido por usuario")
        sys.exit(0)          


