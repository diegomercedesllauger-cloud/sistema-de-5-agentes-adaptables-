import socket
import threading
import sys
from datetime import datetime
from typing import Dict, List, Tuple

class PortScanner:
    """
    Scanner de puertos para reconocimiento de seguridad.
    
    Propósito: Identificar qué puertos están abiertos en una IP objetivo.
    
    ADVERTENCIA: Solo usar en máquinas autorizadas (laboratorio, máquinas virtuales propias).
    Usar en máquinas de otros es ILEGAL.
    
    Autor: Diego Mercedes Llauger (2026-0048)
    """
    
    # Base de datos de puertos conocidos
    PUERTOS_CONOCIDOS = {
        21: {"servicio": "FTP", "protocolo": "TCP", "riesgo": "CRÍTICO",
             "descripción": "Transferencia de archivos (sin cifrado)"},
        22: {"servicio": "SSH", "protocolo": "TCP", "riesgo": "ALTO",
             "descripción": "Acceso remoto seguro (blanco común de fuerza bruta)"},
        23: {"servicio": "Telnet", "protocolo": "TCP", "riesgo": "CRÍTICO",
             "descripción": "Acceso remoto sin cifrado (PELIGROSO)"},
