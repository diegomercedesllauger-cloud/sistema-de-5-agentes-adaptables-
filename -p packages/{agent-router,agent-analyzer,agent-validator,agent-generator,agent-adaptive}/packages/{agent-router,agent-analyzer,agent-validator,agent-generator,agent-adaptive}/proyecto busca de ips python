             "descripción": "Resolución de nombres"},
        80: {"servicio": "HTTP", "protocolo": "TCP", "riesgo": "MEDIO",
             "descripción": "Web sin cifrado"},
        110: {"servicio": "POP3", "protocolo": "TCP", "riesgo": "BAJO",
              "descripción": "Recibir correos"},
        143: {"servicio": "IMAP", "protocolo": "TCP", "riesgo": "BAJO",
              "descripción": "Recibir correos"},
        443: {"servicio": "HTTPS", "protocolo": "TCP", "riesgo": "BAJO",
              "descripción": "Web cifrado (seguro)"},
        3306: {"servicio": "MySQL", "protocolo": "TCP", "riesgo": "ALTO",
               "descripción": "Base de datos (inyección SQL)"},
        3389: {"servicio": "RDP", "protocolo": "TCP", "riesgo": "ALTO",
               "descripción": "Escritorio remoto Windows"},
        5432: {"servicio": "PostgreSQL", "protocolo": "TCP", "riesgo": "ALTO",
               "descripción": "Base de datos"},
        8080: {"servicio": "HTTP alternativo", "protocolo": "TCP", "riesgo": "MEDIO",
               "descripción": "Web alternativo"},
        8443: {"servicio": "HTTPS alternativo", "protocolo": "TCP", "riesgo": "BAJO",
               "descripción": "Web cifrado alternativo"},
    }
    
    def __init__(self, timeout: int = 3):
        """
        Inicializa el scanner.
        
        Args:
            timeout (int): Segundos para esperar respuesta de cada puerto
        """
        self.timeout = timeout
        self.puertos_abiertos = []
        self.puertos_cerrados = []
        self.puertos_filtrados = []
        self.lock = threading.Lock()  # Para seguridad en threads
    
    def escanear_puerto(self, ip: str, puerto: int) -> str:
        """
        Intenta conexión a un puerto específico.
        
        Args:
            ip (str): IP objetivo
            puerto (int): Puerto a escanear
        
        Returns:
            str: "abierto", "cerrado" o "filtrado"
        """
        try:
            # Crear socket
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(self.timeout)
            
            # Intentar conectar
            resultado = sock.connect_ex((ip, puerto))
            sock.close()
            
            # Interpretar resultado
            if resultado == 0:
                return "abierto"
            else:
                return "cerrado"
        
        except socket.timeout:
            return "filtrado"
        except Exception as e:
            print(f"Error en puerto {puerto}: {e}")
            return "error"
    
    def escanear_rango(self, ip: str, puertos: List[int]) -> Dict:
        """
        Escanea múltiples puertos (versión simple, no threaded).
        
        Args:
            ip (str): IP objetivo
            puertos (List[int]): Lista de puertos a escanear
        
        Returns:
            Dict: Resultados del escaneo
        """
        print(f"\n[*] Escaneando {ip}...")
        print(f"[*] Total de puertos: {len(puertos)}")
        print(f"[*] Timeout: {self.timeout} segundos\n")
        
        inicio = datetime.now()
        
        for i, puerto in enumerate(puertos, 1):
            estado = self.escanear_puerto(ip, puerto)
            
            # Mostrar progreso
            print(f"[{i}/{len(puertos)}] Puerto {puerto}: {estado.upper()}", end="\r")
            
            # Clasificar resultado
            if estado == "abierto":
                self.puertos_abiertos.append(puerto)
                print(f"[✓] Puerto {puerto} ABIERTO " + " " * 20)
            
            elif estado == "filtrado":
                self.puertos_filtrados.append(puerto)
            
            else:
                self.puertos_cerrados.append(puerto)
        
        tiempo_total = (datetime.now() - inicio).total_seconds()
        
        # Retornar resultados
        return {
            "ip": ip,
            "puertos_abiertos": self.puertos_abiertos,
            "puertos_cerrados": self.puertos_cerrados,
            "puertos_filtrados": self.puertos_filtrados,
            "tiempo_total": tiempo_total,
            "detalles": self._obtener_detalles()
        }
    
    def _obtener_detalles(self) -> Dict:
        """Obtiene información detallada de puertos abiertos."""
        detalles = {}
        
        for puerto in self.puertos_abiertos:
            if puerto in self.PUERTOS_CONOCIDOS:
                detalles[puerto] = self.PUERTOS_CONOCIDOS[puerto]
            else:
                detalles[puerto] = {
                    "servicio": "Desconocido",
                    "protocolo": "TCP",
                    "riesgo": "DESCONOCIDO",
                    "descripción": "Servicio no registrado"
                }
        
        return detalles
    
    def _calcular_riesgo_general(self) -> str:
        """Calcula el nivel de riesgo general basado en puertos abiertos."""
        
        puertos_criticos = 0
        puertos_altos = 0
        
        for puerto in self.puertos_abiertos:
            if puerto in self.PUERTOS_CONOCIDOS:
                riesgo = self.PUERTOS_CONOCIDOS[puerto]["riesgo"]
                
                if riesgo == "CRÍTICO":
                    puertos_criticos += 1
                elif riesgo == "ALTO":
                    puertos_altos += 1
        
        # Determinar riesgo general
        if puertos_criticos > 0:
            return f"🔴 CRÍTICO ({puertos_criticos} puertos críticos abiertos)"
        elif puertos_altos >= 2:
            return f"🟠 ALTO ({puertos_altos} puertos de alto riesgo)"
        elif puertos_altos > 0:
            return f"🟡 MEDIO ({puertos_altos} puerto de alto riesgo)"
        else:
            return "🟢 BAJO (sin puertos críticos abiertos)"
    
    def mostrar_resultados(self, resultados: Dict):
        """Muestra los resultados en formato profesional."""
        
        print("\n" + "="*60)
        print("RESULTADOS DEL ESCANEO DE PUERTOS")
        print("="*60)
        
        print(f"\nIP objetivo: {resultados['ip']}")
        print(f"Puertos abiertos: {len(resultados['puertos_abiertos'])}")
        print(f"Puertos cerrados: {len(resultados['puertos_cerrados'])}")
        print(f"Puertos filtrados: {len(resultados['puertos_filtrados'])}")
        print(f"Tiempo total: {resultados['tiempo_total']:.2f} segundos")
        
        # Mostrar detalles de puertos abiertos
        if resultados['detalles']:
            print("\n" + "-"*60)
            print("DETALLES DE PUERTOS ABIERTOS")
            print("-"*60)
            
            for puerto, info in sorted(resultados['detalles'].items()):
                print(f"\n📍 Puerto {puerto}: {info['servicio']}")
                print(f"   Protocolo: {info['protocolo']}")
                print(f"   Riesgo: {info['riesgo']}")
                print(f"   Descripción: {info['descripción']}")
        
        # Riesgo general
        print("\n" + "-"*60)
        riesgo = self._calcular_riesgo_general()
        print(f"Riesgo de seguridad: {riesgo}")
        print("-"*60)
        
        # Recomendaciones
        print("\n📋 RECOMENDACIONES:")
        if len(resultados['puertos_abiertos']) > 0:
            print("   1. Próximo paso: Enumerar versiones de servicios (AGENTE 3)")
            print("   2. Buscar vulnerabilidades conocidas (AGENTE 4)")
            print("   3. Intentar acceso si está autorizado (AGENTE 5)")
        else:
            print("   ✓ No hay puertos abiertos en rango común")
            print("   • Intenta escaneo completo si necesitas verificación total")


def main():
