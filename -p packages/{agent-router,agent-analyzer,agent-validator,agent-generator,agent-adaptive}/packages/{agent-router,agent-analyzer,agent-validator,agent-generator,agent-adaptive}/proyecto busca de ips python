                "descripción": "Denial of Service via HTTP/2",
                "severidad": "MEDIA",
                "cvss": "5.9",
                "impacto": "Denegación de servicio"
            }
        ],
        ("nginx", "1.14.0"): [
            {
                "cve": "CVE-2019-9511",
                "descripción": "HTTP/2 WINDOW_UPDATE DoS",
                "severidad": "MEDIA",
                "cvss": "6.5",
                "impacto": "Denegación de servicio"
            }
        ],
        ("MySQL", "5.7.25"): [
            {
                "cve": "CVE-2018-3282",
                "descripción": "Information disclosure",
                "severidad": "MEDIA",
                "cvss": "4.0",
                "impacto": "Lectura de información sensible"
            }
        ]
    }
    
    def __init__(self, timeout: int = 5):
        """
        Inicializa enumerador.
        
        Args:
            timeout (int): Segundos para esperar respuesta
        """
        self.timeout = timeout
    
    def enumerar_puerto(self, ip: str, puerto: int) -> Dict:
        """
        Enumera un puerto específico para obtener información de servicio.
        
        Args:
            ip (str): IP objetivo
            puerto (int): Puerto a enumerar
        
        Returns:
            Dict: Información del servicio o error
        """
        
        print(f"\n[*] Enumerando {ip}:{puerto}...")
        
        # Paso 1: Obtener banner
        banner = self._obtener_banner(ip, puerto)
        
        if not banner:
            return {
                "puerto": puerto,
                "estado": "sin_respuesta",
                "razón": "El servidor no respondió"
            }
        
        print(f"[+] Banner obtenido: {banner[:50]}...")
        
        # Paso 2: Parsear banner
        servicio_info = self._parsear_banner(banner)
        
        if not servicio_info:
            return {
                "puerto": puerto,
                "estado": "identificación_fallida",
                "banner_crudo": banner,
                "razón": "No se pudo identificar el servicio"
            }
        
        # Paso 3: Buscar CVEs
        clave_cve = (servicio_info["servicio"], servicio_info["versión"])
        vulnerabilidades = self.CVE_DATABASE.get(clave_cve, [])
        
        # Paso 4: Generar recomendación
        recomendación = self._generar_recomendación(
            servicio_info["servicio"],
            vulnerabilidades
        )
        
        return {
            "puerto": puerto,
            "estado": "identificado",
            "banner_crudo": banner,
            "servicio": servicio_info["servicio"],
            "versión": servicio_info["versión"],
            "protocolo": servicio_info.get("protocolo", "desconocido"),
            "cve_conocidas": vulnerabilidades,
            "cve_count": len(vulnerabilidades),
            "riesgo": self._calcular_riesgo(vulnerabilidades),
            "recomendación": recomendación,
            "timestamp": datetime.now().isoformat()
        }
    
    def _obtener_banner(self, ip: str, puerto: int) -> Optional[str]:
        """
        Se conecta a un puerto y obtiene el banner (respuesta inicial).
        
        Args:
            ip (str): IP objetivo
            puerto (int): Puerto
        
        Returns:
            Optional[str]: Banner o None
        """
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(self.timeout)
            
            # Conectar
            sock.connect((ip, puerto))
            
            # Algunos servidores responden sin enviar nada
            # Otros responden cuando les hablas
            # Intentamos ambos
            
            try:
                # Esperar respuesta espontánea
                banner = sock.recv(1024).decode('utf-8', errors='ignore')
                if banner:
                    sock.close()
                    return banner.strip()
            except socket.timeout:
                pass
            
            # Si no respondió, intentar con "hello"
            # (para servicios que esperan interacción)
            try:
                sock.send(b"HELP\r\n")
                banner = sock.recv(1024).decode('utf-8', errors='ignore')
                sock.close()
                return banner.strip() if banner else None
            except:
                pass
            
            sock.close()
            return None
        
        except Exception as e:
            print(f"  [-] Error conectando: {e}")
            return None
    
    def _parsear_banner(self, banner: str) -> Optional[Dict]:
        """
        Extrae servicio y versión del banner.
        
        Args:
            banner (str): Respuesta del servidor
        
        Returns:
            Optional[Dict]: Info de servicio o None
        """
        
        # OpenSSH
        if "OpenSSH" in banner:
            match = re.search(r"OpenSSH_([0-9.]+)", banner)
            if match:
                return {
                    "servicio": "OpenSSH",
                    "versión": match.group(1),
                    "protocolo": "SSH"
                }
        
        # Apache
        if "Apache" in banner:
            match = re.search(r"Apache/([0-9.]+)", banner)
            if match:
                return {
                    "servicio": "Apache",
                    "versión": match.group(1),
                    "protocolo": "HTTP"
                }
        
        # nginx
        if "nginx" in banner:
            match = re.search(r"nginx/([0-9.]+)", banner)
            if match:
                return {
                    "servicio": "nginx",
                    "versión": match.group(1),
                    "protocolo": "HTTP"
                }
        
        # MySQL
        if "MySQL" in banner or re.search(r"^[0-9.]+", banner):
            match = re.search(r"([0-9]+\.[0-9]+\.[0-9]+)", banner)
            if match:
                return {
                    "servicio": "MySQL",
                    "versión": match.group(1),
                    "protocolo": "MySQL"
                }
        
        # Si el banner contiene versión pero no identificamos
        return None
    
    def _calcular_riesgo(self, vulnerabilidades: List[Dict]) -> str:
        """Calcula nivel de riesgo basado en CVEs."""
        
        if not vulnerabilidades:
            return "🟢 BAJO (sin CVEs conocidas)"
        
        severidades = [cve.get("severidad", "") for cve in vulnerabilidades]
        
        if any(s == "CRÍTICA" for s in severidades):
            return "🔴 CRÍTICO"
        elif any(s == "ALTA" for s in severidades):
            return "🟠 ALTO"
        elif any(s == "MEDIA" for s in severidades):
            return "🟡 MEDIO"
        else:
            return "🟢 BAJO"
    
    def _generar_recomendación(self, servicio: str, 
                               vulnerabilidades: List[Dict]) -> str:
