  """
🤖 ORQUESTADOR - Maestro de agentes
============================================
Este módulo coordina todos los agentes.

Analogía: Es como un director de orquesta que:
1. Dice cuándo toca cada instrumento (agente)
2. Asegura que cada uno solo reciba lo que necesita (optimiza tokens)
3. Recuerda lo que aprendió de cada músico (preferencias del usuario)
"""

import json
