    orchestrator = OrchestrationHub()
    
    # Registrar los 5 agentes
    orchestrator.register_agent("router", RouterAgent)
    orchestrator.register_agent("analyzer", AnalyzerAgent)
    orchestrator.register_agent("validator", ValidatorAgent)
    orchestrator.register_agent("generator", GeneratorAgent)
    orchestrator.register_agent("adaptive", AdaptiveAgent)
    
    print("✓ Orquestador configurado con 5 agentes")
    return orchestrator


# PASO 3: Función para ejecutar todo (interfaz simple)
def run_pipeline(user_input: str, user_id: str = "default"):
    """
    Ejecuta todo el pipeline de forma simple
    
    Uso:
        resultado = run_pipeline("Necesito un sistema de agentes")
    """
    orchestrator = create_configured_orchestrator()
    return orchestrator.execute_pipeline(user_input, user_id)


# PASO 4: Función para procesar feedback
def learn_from_feedback(user_id: str, feedback: str):
    """
    Procesa feedback y adapta el sistema
    
    Uso:
        learn_from_feedback("diego_2026_0048", "Eso fue muy técnico")
    """
    orchestrator = create_configured_orchestrator()
    return orchestrator.process_feedback(user_id, feedback, task_type="código")


